{
  "name": "pi-ynabro",
  "version": "0.1.0",
  "description": "Pi extension that registers YNABro tools for YNAB integration",
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src",
    "full_logo.png",
    "logo.png",
    "README.md",
    "skills"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jmcombs/ynabro.git",
    "directory": "packages/pi-ynabro"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "matched-transaction-reviewer"
    ]
  },
  "dependencies": {
    "ynabro": "file:../.."
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  }
}
